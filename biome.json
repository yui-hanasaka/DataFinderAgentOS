{
    "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
    "assist": { "actions": { "source": { "organizeImports": "on" } } },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "suspicious": { "noExplicitAny": "warn" },
            "style": { "useConst": "error" }
        }
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "files": {
        "includes": ["**/app/static/js/**/*.js", "**/app/static/css/**/*.css"]
    }
}
